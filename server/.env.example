# ── TigerGraph Cloud credentials ──────────────────────────────
# Get these from your TigerGraph Cloud dashboard at tgcloud.io

# Your cluster hostname (NO trailing slash, NO port)
# Example: https://abc123.i.tgcloud.io
TG_HOST=https://YOUR_CLUSTER.i.tgcloud.io

# Graph name (must match what you created in GSQL Studio)
TG_GRAPH=GraphSense

# Bearer token — generate from TG Studio > Admin > Token Management
TG_TOKEN=your_bearer_token_here

# Local server port
PORT=4000
